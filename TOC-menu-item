export function scrollToIntro(Component): ComponentType {
    return (props) => (
        <Component
            {...props}
            onTap={() =>
                document
                    .getElementById("intro")
                    ?.scrollIntoView({ behavior: "smooth", block: "start" })
            }
        />
    )
}

